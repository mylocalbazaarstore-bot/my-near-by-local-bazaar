{
  "info": {
    "name": "MyLocalBazaar.store — Complete API Test Suite",
    "description": "All Phase 1 + Phase 2 + Phase 3 endpoints\nBase URL: http://localhost:5000/api/v1\nCompany: Catalyst Service Private Limited\nVersion: 3.0.0",
    "_postman_id": "mlb-api-v3",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL",         "value": "http://localhost:5000/api/v1" },
    { "key": "CUSTOMER_TOKEN",   "value": "" },
    { "key": "MERCHANT_TOKEN",   "value": "" },
    { "key": "ADMIN_TOKEN",      "value": "" },
    { "key": "DELIVERY_TOKEN",   "value": "" },
    { "key": "CUSTOMER_PHONE",   "value": "9999999999" },
    { "key": "MERCHANT_PHONE",   "value": "8888888888" },
    { "key": "TEST_ORDER_ID",    "value": "" },
    { "key": "TEST_PRODUCT_ID",  "value": "" },
    { "key": "TEST_CART_ITEM_ID","value": "" }
  ],
  "item": [

    {
      "name": "🏥 HEALTH CHECK",
      "item": [
        {
          "name": "Health Check",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Version 3.0.0', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.version).to.eql('3.0.0');",
              "  pm.expect(json.services.database.status).to.eql('healthy');",
              "  pm.expect(json.services.redis.status).to.eql('healthy');",
              "});"
            ]}
          }],
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/health"
          }
        }
      ]
    },

    {
      "name": "🔐 PHASE 1 — AUTH",
      "item": [
        {
          "name": "Customer — Send OTP",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('OTP sent', () => pm.expect(pm.response.json().data.sent).to.be.true);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/auth/customer/send-otp",
            "body": { "mode": "raw", "raw": "{ \"phone\": \"{{CUSTOMER_PHONE}}\" }" }
          }
        },
        {
          "name": "Customer — Verify OTP (Dev: 123456)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "if (json.data && json.data.tokens) {",
            "  pm.collectionVariables.set('CUSTOMER_TOKEN', json.data.tokens.access_token);",
            "  pm.test('Token received', () => pm.expect(json.data.tokens.access_token).to.be.a('string'));",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/auth/customer/verify-otp",
            "body": { "mode": "raw", "raw": "{ \"phone\": \"{{CUSTOMER_PHONE}}\", \"otp\": \"123456\" }" }
          }
        },
        {
          "name": "Merchant — Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "if (json.data && json.data.tokens) {",
            "  pm.collectionVariables.set('MERCHANT_TOKEN', json.data.tokens.access_token);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/auth/merchant/login",
            "body": { "mode": "raw", "raw": "{ \"phone\": \"{{MERCHANT_PHONE}}\", \"password\": \"Test@1234\" }" }
          }
        },
        {
          "name": "Admin — Login (Step 1: Email+Password)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('2FA OTP sent', () => pm.expect(pm.response.json().data.otp_sent).to.be.true);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/auth/admin/login",
            "body": { "mode": "raw", "raw": "{ \"email\": \"admin@mylocalbazaar.store\", \"password\": \"Admin@12345\" }" }
          }
        },
        {
          "name": "Admin — Verify 2FA OTP",
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "if (json.data && json.data.tokens) {",
            "  pm.collectionVariables.set('ADMIN_TOKEN', json.data.tokens.access_token);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/auth/admin/verify-2fa",
            "body": { "mode": "raw", "raw": "{ \"email\": \"admin@mylocalbazaar.store\", \"otp\": \"123456\" }" }
          }
        },
        {
          "name": "Customer — Get Profile (me)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has user data', () => pm.expect(pm.response.json().data.user).to.exist);"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{CUSTOMER_TOKEN}}" }],
            "url": "{{BASE_URL}}/auth/customer/me"
          }
        }
      ]
    },

    {
      "name": "📦 PHASE 1 — PRODUCTS & CATEGORIES",
      "item": [
        {
          "name": "Get All Categories",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has categories', () => {",
            "  const data = pm.response.json().data;",
            "  pm.expect(data).to.be.an('array').with.length.above(0);",
            "});"
          ]}}],
          "request": { "method": "GET", "url": "{{BASE_URL}}/categories" }
        },
        {
          "name": "Area Search — Kharghar",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{BASE_URL}}/areas/search?q=Kharghar" }
        },
        {
          "name": "Area Search — By Pincode",
          "request": { "method": "GET", "url": "{{BASE_URL}}/areas/pincode/410210" }
        },
        {
          "name": "Merchants by Pincode",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "if (json.data && json.data.rows && json.data.rows.length > 0) {",
            "  pm.collectionVariables.set('TEST_MERCHANT_ID', json.data.rows[0].id);",
            "}"
          ]}}],
          "request": { "method": "GET", "url": "{{BASE_URL}}/merchants/by-pincode/410210?sort_by=rating&limit=5" }
        },
        {
          "name": "Merchant — List Products",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "if (json.data && json.data.rows && json.data.rows.length > 0) {",
            "  pm.collectionVariables.set('TEST_PRODUCT_ID', json.data.rows[0].id);",
            "}"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{MERCHANT_TOKEN}}" }],
            "url": "{{BASE_URL}}/merchant/products?limit=5"
          }
        },
        {
          "name": "Merchant — Create Product",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{MERCHANT_TOKEN}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{BASE_URL}}/merchant/products",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test Product — Fresh Tomatoes 1kg\",\n  \"category_id\": \"REPLACE_WITH_CATEGORY_ID\",\n  \"mrp\": 50.00,\n  \"retail_price\": 40.00,\n  \"stock_quantity\": 100,\n  \"unit\": \"kg\",\n  \"moq\": 1,\n  \"gst_percentage\": 0\n}" }
          }
        },
        {
          "name": "Merchant — Dashboard Overview",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has overview data', () => {",
            "  const data = pm.response.json().data;",
            "  pm.expect(data).to.exist;",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{MERCHANT_TOKEN}}" }],
            "url": "{{BASE_URL}}/merchant/dashboard/overview?period=month"
          }
        }
      ]
    },

    {
      "name": "🛒 PHASE 1 — CART & ORDERS (Double-Approval Flow)",
      "item": [
        {
          "name": "1. Get Cart",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Cart structure valid', () => {",
            "  const cart = pm.response.json().data.cart;",
            "  pm.expect(cart).to.have.property('item_count');",
            "  pm.expect(cart).to.have.property('totals');",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{CUSTOMER_TOKEN}}" }],
            "url": "{{BASE_URL}}/cart"
          }
        },
        {
          "name": "2. Add Item to Cart",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "if (json.data && json.data.cart_item) {",
            "  pm.collectionVariables.set('TEST_CART_ITEM_ID', json.data.cart_item.id);",
            "  pm.test('Cart item created', () => pm.expect(json.data.cart_item.id).to.exist);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{CUSTOMER_TOKEN}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{BASE_URL}}/cart/items",
            "body": { "mode": "raw", "raw": "{ \"product_id\": \"{{TEST_PRODUCT_ID}}\", \"quantity\": 2 }" }
          }
        },
        {
          "name": "3. Update Cart Item Qty",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{CUSTOMER_TOKEN}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{BASE_URL}}/cart/items/{{TEST_CART_ITEM_ID}}",
            "body": { "mode": "raw", "raw": "{ \"quantity\": 3 }" }
          }
        },
        {
          "name": "4. Get Delivery Estimate",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{CUSTOMER_TOKEN}}" }],
            "url": "{{BASE_URL}}/cart/delivery-charge?address_id=REPLACE_WITH_ADDRESS_ID"
          }
        },
        {
          "name": "5. Place Order — COD",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 or 201', () => {",
            "  pm.expect([200,201]).to.include(pm.response.code);",
            "});",
            "const json = pm.response.json();",
            "if (json.data && json.data.order) {",
            "  pm.collectionVariables.set('TEST_ORDER_ID', json.data.order.id);",
            "  pm.test('Order ID set', () => pm.expect(json.data.order.id).to.exist);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{CUSTOMER_TOKEN}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{BASE_URL}}/orders",
            "body": { "mode": "raw", "raw": "{\n  \"address_id\": \"REPLACE_WITH_ADDRESS_ID\",\n  \"payment_method\": \"cod\",\n  \"notes\": \"Postman test order\"\n}" }
          }
        },
        {
          "name": "6. Get My Orders",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Orders list exists', () => pm.expect(pm.response.json().data.rows).to.be.an('array'));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{CUSTOMER_TOKEN}}" }],
            "url": "{{BASE_URL}}/orders?limit=5"
          }
        },
        {
          "name": "7. [MERCHANT] Get Pending Orders",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const data = pm.response.json().data;",
            "pm.test('Pending orders structure', () => {",
            "  pm.expect(data.count).to.be.a('number');",
            "  pm.expect(data.orders).to.be.an('array');",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{MERCHANT_TOKEN}}" }],
            "url": "{{BASE_URL}}/merchant/orders/pending"
          }
        },
        {
          "name": "8. [MERCHANT] Approve Order ★ Double-Approval",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Order approved', () => {",
            "  const data = pm.response.json().data;",
            "  pm.expect(data.order_status).to.eql('merchant_approved');",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{MERCHANT_TOKEN}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{BASE_URL}}/merchant/orders/{{TEST_ORDER_ID}}/action",
            "body": { "mode": "raw", "raw": "{ \"action\": \"approve\", \"estimated_delivery_minutes\": 30 }" }
          }
        },
        {
          "name": "9. [MERCHANT] Mark Order Packed",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{MERCHANT_TOKEN}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{BASE_URL}}/merchant/orders/{{TEST_ORDER_ID}}/status",
            "body": { "mode": "raw", "raw": "{ \"status\": \"packed\", \"note\": \"Order ready for pickup\" }" }
          }
        },
        {
          "name": "10. Get Order Detail (with OTP)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Order has timeline', () => {",
            "  const order = pm.response.json().data.order;",
            "  pm.expect(order.status_timeline).to.be.an('array').with.length.above(0);",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{CUSTOMER_TOKEN}}" }],
            "url": "{{BASE_URL}}/orders/{{TEST_ORDER_ID}}"
          }
        }
      ]
    },

