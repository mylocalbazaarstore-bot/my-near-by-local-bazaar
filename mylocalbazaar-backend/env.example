# ============================================================
# MYLOCALBAZAAR.STORE — Environment Variables
# Company: Catalyst Service Private Limited
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER COMMIT .env TO GIT
# ============================================================

# ─────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_NAME=MyLocalBazaar
APP_URL=https://api.mylocalbazaar.store
FRONTEND_URL=https://mylocalbazaar.store
ADMIN_URL=https://admin.mylocalbazaar.store

# ─────────────────────────────────────────
# POSTGRESQL DATABASE
# ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mylocalbazaar_db
DB_USER=mlb_user
DB_PASSWORD=your_strong_db_password_here
DB_SSL=false
# For Railway PostgreSQL, use the full connection string:
# DATABASE_URL=postgresql://user:pass@host:port/dbname?sslmode=require
DATABASE_URL=

# Connection Pool Settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000

# ─────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
# For Railway Redis, use full URL:
# REDIS_URL=redis://:password@host:port
REDIS_URL=

# ─────────────────────────────────────────
# JWT AUTHENTICATION
# ─────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_change_this_immediately
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_also_min_64_chars
JWT_REFRESH_EXPIRES_IN=30d

# ─────────────────────────────────────────
# OTP CONFIGURATION
# ─────────────────────────────────────────
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60
# Set OTP_DEV_MODE=true to use a fixed OTP and skip SMS delivery.
# Use only for testing/demo environments.
OTP_DEV_MODE=false
# Legacy alias; OTP_DEV_MODE is preferred for Railway/testing.
OTP_USE_FIXED_DEV=true
OTP_FIXED_DEV_CODE=123456

# ─────────────────────────────────────────
# SMS / TWILIO
# ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# OR use Fast2SMS (India-specific, cheaper)
FAST2SMS_API_KEY=your_fast2sms_api_key

# ─────────────────────────────────────────
# EMAIL / NODEMAILER
# ─────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=noreply@mylocalbazaar.store
EMAIL_PASSWORD=your_email_app_password
EMAIL_FROM="MyLocalBazaar <noreply@mylocalbazaar.store>"

# ─────────────────────────────────────────
# CLOUDINARY (Image/Media Storage)
# ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=mylocalbazaar

# ─────────────────────────────────────────
# RAZORPAY PAYMENT GATEWAY
# ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
# For testing:
RAZORPAY_TEST_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_TEST_KEY_SECRET=your_razorpay_test_key_secret

# ─────────────────────────────────────────
# GOOGLE MAPS API
# ─────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─────────────────────────────────────────
# WHATSAPP API (Meta Cloud API)
# ─────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# ─────────────────────────────────────────
# FIREBASE (Push Notifications)
# ─────────────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────
# Comma-separated list of allowed admin IP addresses
ADMIN_ALLOWED_IPS=127.0.0.1,::1
# Encryption key for sensitive data at rest (32 bytes hex)
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here_change_this
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://mylocalbazaar.store,https://www.mylocalbazaar.store

# ─────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
OTP_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_MAX=10

# ─────────────────────────────────────────
# PLATFORM FEES & COMMISSIONS
# ─────────────────────────────────────────
PLATFORM_COMMISSION_PERCENT=8
DELIVERY_BASE_CHARGE=20
DELIVERY_PER_KM_CHARGE=5
FREE_DELIVERY_ABOVE=500

# ─────────────────────────────────────────
# CLOUDFLARE (Production CDN)
# ─────────────────────────────────────────
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# ─────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# ─────────────────────────────────────────
# PAGINATION DEFAULTS
# ─────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
